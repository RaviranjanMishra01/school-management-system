<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= school 
      ? `School Created – ${schoolId}` 
      : teacher 
      ? `Teacher Account – ${teacherId}`
      : "Welcome – CoolManagement" %>
  </title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --success: #10b981;
      --text: #1e293b;
      --text-light: #64748b;
      --card: #ffffff;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 28px;
      --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f7ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: var(--text);
    }

    .success-card {
      width: 100%;
      max-width: 520px;
      background: var(--card);
      padding: 64px 52px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border: 1px solid rgba(26, 115, 232, 0.12);
      position: relative;
      overflow: hidden;
      animation: floatIn 0.9s ease-out;
    }

    .success-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 7px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .icon-success {
      width: 96px;
      height: 96px;
      background: linear-gradient(135deg, #10b981, #34d399);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 44px;
      margin: 0 auto 32px;
      box-shadow: 0 16px 40px rgba(16, 185, 129, 0.35);
    }

    h1 {
      font-size: 36px;
      font-weight: 800;
      margin-bottom: 12px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      font-size: 17px;
      color: var(--text-light);
      margin-bottom: 36px;
      line-height: 1.6;
    }

    .id-box {
      background: #f8faff;
      border: 2px dashed var(--primary);
      border-radius: 18px;
      padding: 24px;
      margin: 32px 0;
      font-size: 18px;
      font-weight: 600;
    }

    .id-label {
      color: var(--text-light);
      display: block;
      margin-bottom: 8px;
      font-size: 15px;
    }

    .id-value {
      color: var(--primary);
      font-size: 28px;
      font-weight: 800;
      letter-spacing: 1px;
      word-break: break-all;
    }

    .btn {
      display: block;
      width: 100%;
      padding: 18px;
      margin: 12px 0;
      border-radius: 16px;
      font-size: 17px;
      font-weight: 700;
      text-decoration: none;
      text-align: center;
      transition: var(--transition);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      box-shadow: 0 10px 30px rgba(26, 115, 232, 0.3);
    }

    .btn-primary:hover {
      transform: translateY(-5px);
      box-shadow: 0 18px 40px rgba(26, 115, 232, 0.4);
    }

    .btn-outline {
      background: transparent;
      color: var(--primary);
      border: 2px solid var(--primary);
    }

    .btn-outline:hover {
      background: var(--primary);
      color: white;
    }

    .btn-success {
      background: linear-gradient(135deg, #10b981, #34d399);
      color: white;
      box-shadow: 0 10px 30px rgba(16, 185, 129, 0.3);
    }

    .btn-success:hover {
      transform: translateY(-5px);
      box-shadow: 0 18px 40px rgba(16, 185, 129, 0.4);
    }

    .actions {
      margin-top: 20px;
      display: grid;
      gap: 14px;
    }

    @media (max-width: 480px) {
      .success-card { padding: 52px 36px; }
      h1 { font-size: 30px; }
      .id-value { font-size: 24px; }
    }
  </style>
</head>
<body>

  <div class="success-card">

    <div class="icon-success">
      <i class="fas fa-check"></i>
    </div>

    <h1>
      <% if (school && schoolId) { %>
        School Created Successfully!
      <% } else if (teacher && teacherId) { %>
        Welcome, Teacher!
      <% } else { %>
        Welcome to CoolManagement
      <% } %>
    </h1>

    <p class="subtitle">
      <% if (school && schoolId) { %>
        Your school has been set up successfully. Use the School ID below to log in.
      <% } else if (teacher && teacherId) { %>
        Your teacher account is ready. Use your Teacher ID to access your dashboard.
      <% } else { %>
        You’re all set! Choose how you’d like to continue.
      <% } %>
    </p>

    <!-- ID Display -->
    <% if (school && schoolId) { %>
      <div class="id-box">
        <div class="id-label">Your School ID</div>
        <div class="id-value"><%= schoolId %></div>
      </div>
    <% } else if (teacher && teacherId) { %>
      <div class="id-box">
        <div class="id-label">Your Teacher ID</div>
        <div class="id-value"><%= teacherId %></div>
      </div>
    <% } %>

    <div class="actions">

      <a href="/" class="btn btn-outline">
        Home Page
      </a>

      <% if (school && schoolId) { %>
        <a href="/school/dashboard" class="btn btn-success">
          Go to School Dashboard
        </a>
      <% } %>

      <a href="/school/login" class="btn btn-outline">
        School Login
      </a>

      <a href="/teacher/login" class="btn btn-outline">
        Teacher Login
      </a>

    </div>

  </div>

</body>
</html>
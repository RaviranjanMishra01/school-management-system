<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EduManage.png — Modern School Management System</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/styles/nav.css" />
  <link rel="stylesheet" href="/styles/footer.css" />

  <style>
     * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #f6f9fe;
      color: #0a1c2f;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    /* premium glass + gradient variables */
    :root {
      --primary: #2b6eff;
      --primary-dark: #1a4fcf;
      --primary-glow: rgba(43, 110, 255, 0.25);
      --secondary: #7000ff;
      --accent: #00c6b9;
      --dark-bg: #0b1120;
      --card-bg: rgba(255, 255, 255, 0.96);
      --shadow-soft: 0 18px 35px -12px rgba(0, 0, 0, 0.08), 0 6px 12px -6px rgba(0, 0, 0, 0.02);
      --shadow-lifted: 0 35px 45px -18px rgba(0, 0, 0, 0.2), 0 10px 20px -6px rgba(0, 0, 0, 0.05);
      --border-glow: linear-gradient(145deg, rgba(43,110,255,0.35), rgba(112,0,255,0.2));
    }

    /* ===== HERO SECTION ===== */
    .hero {
      position: relative;
      background: radial-gradient(circle at 10% 30%, #0a2540, #030e1a);
      color: white;
      text-align: center;
      padding: 190px 24px 160px;
      overflow: hidden;
      isolation: isolate;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: url('data:image/svg+xml;base64,') bottom no-repeat;
      background-size: cover;
      opacity: 0.6;
      pointer-events: none;
    }

    .hero h1 {
      font-size: 64px;
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #ffffff, #b9e0ff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 24px;
    }

    .hero p {
      font-size: 1.35rem;
      max-width: 720px;
      margin: 0 auto 42px;
      font-weight: 500;
      color: #eef5ff;
      backdrop-filter: blur(2px);
    }

    .btn-primary {
      display: inline-block;
      background: white;
      color: #1a4fcf !important;
      padding: 18px 48px;
      border-radius: 60px;
      font-weight: 700;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      box-shadow: 0 18px 32px -10px rgba(0, 0, 0, 0.25);
      text-decoration: none;
      border: none;
    }

    .btn-primary:hover {
      transform: translateY(-5px);
      box-shadow: 0 28px 45px -12px rgba(0, 0, 0, 0.35);
      background: #fefefe;
    }

    .btn-secondary {
      display: inline-block;
      background: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(12px);
      border: 1.5px solid rgba(255, 255, 255, 0.4);
      color: white !important;
      padding: 16px 40px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .btn-secondary:hover {
      background: white;
      color: #0a2540 !important;
      border-color: white;
      transform: translateY(-3px);
    }

    /* ===== FEATURES SECTION ===== */
    .features-section {
      padding: 110px 24px;
      background: #f9fcff;
      position: relative;
    }

    .section-title {
      font-size: 48px;
      font-weight: 800;
      text-align: center;
      background: linear-gradient(125deg, #0a2b44, #2b6eff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.01em;
      margin-bottom: 20px;
    }

    .section-subtitle {
      text-align: center;
      font-size: 1.2rem;
      color: #3a5670;
      max-width: 700px;
      margin: 0 auto 70px auto;
      font-weight: 450;
    }

    /* PREMIUM CARD GRID - glassmorphic + gradient borders + depth */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
      gap: 40px;
      max-width: 1300px;
      margin: 0 auto;
    }

    .feature-card {
      background: var(--card-bg);
      backdrop-filter: blur(2px);
      border-radius: 40px;
      padding: 44px 28px 40px;
      transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      border: 1px solid rgba(43, 110, 255, 0.15);
      box-shadow: var(--shadow-soft);
      position: relative;
      overflow: hidden;
    }

    /* premium gradient border effect */
    .feature-card::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 40px;
      padding: 2px;
      background: var(--border-glow);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
    }

    .feature-card:hover::before {
      opacity: 1;
    }

    .feature-card:hover {
      transform: translateY(-14px) scale(1.01);
      box-shadow: var(--shadow-lifted);
      border-color: rgba(43, 110, 255, 0.3);
      background: #ffffff;
    }

    /* icon area — vibrant premium gradient icons */
    .feature-icon {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 78px;
      height: 78px;
      background: linear-gradient(145deg, #eef5ff, #ffffff);
      border-radius: 28px;
      box-shadow: 0 12px 18px -8px rgba(43, 110, 255, 0.2);
      color: #2b6eff;
      transition: all 0.3s;
    }

    .feature-icon i {
      font-size: 2.3rem;
      background: linear-gradient(135deg, #2b6eff, #8760ff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .feature-card h3 {
      font-size: 1.8rem;
      font-weight: 700;
      letter-spacing: -0.3px;
      margin-bottom: 18px;
      color: #0c2942;
    }

    .feature-card p {
      color: #3e5a77;
      font-weight: 500;
      line-height: 1.55;
      font-size: 1rem;
    }

    /* SECOND CTA block (premium dark gradient) */
    .cta-section {
      padding: 110px 24px;
      text-align: center;
      background: linear-gradient(125deg, #0b1120 0%, #141e33 100%);
      color: white;
      position: relative;
      overflow: hidden;
    }

    .cta-section::after {
      content: "";
      position: absolute;
      top: -30%;
      left: -10%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(43,110,255,0.2), transparent);
      border-radius: 50%;
      pointer-events: none;
    }

    .cta-section h2 {
      font-size: 48px;
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(125deg, #ffffff, #b0dcff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 28px;
    }

    .cta-section p {
      font-size: 1.25rem;
      max-width: 680px;
      margin: 0 auto 48px;
      opacity: 0.9;
      font-weight: 450;
    }

    .cta-flex {
      display: flex;
      gap: 28px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* badge + responsive */
    @media (max-width: 740px) {
      .hero h1 { font-size: 44px; }
      .hero p { font-size: 1.1rem; }
      .section-title, .cta-section h2 { font-size: 36px; }
      .feature-card { padding: 36px 24px; }
      .feature-icon { width: 68px; height: 68px; }
    }

    /* extra polish for links and button inside cta */
    .cta-section .btn-primary {
      background: white;
      color: #0b1120 !important;
      box-shadow: 0 15px 30px -12px rgba(0,0,0,0.3);
    }
    .cta-section .btn-primary:hover {
      background: #f0f4ff;
      transform: translateY(-4px);
    }
    .cta-section .btn-secondary {
      background: rgba(255,255,255,0.08);
      border: 1.5px solid rgba(255,255,255,0.35);
    }
    .cta-section .btn-secondary:hover {
      background: white;
      color: #0b1120 !important;
    }

    /* mimic premium modular nav & footer (replace includes as actual html for this preview) */
    .navbar-premium {
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(20px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.03);
      position: sticky;
      top: 0;
      z-index: 1000;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 5%;
      height: 80px;
    }
    .logo {
      font-weight: 800;
      font-size: 1.5rem;
      background: linear-gradient(135deg, #2b6eff, #7000ff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
    }
    .nav-links a {
      margin-left: 2rem;
      text-decoration: none;
      font-weight: 500;
      color: #1a2c42;
      transition: 0.2s;
    }
    .nav-links a:hover { color: #2b6eff; }
    .footer-premium {
      background: #0c0f1a;
      color: #cbd5e6;
      padding: 48px 24px 32px;
      text-align: center;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .footer-premium .footer-content {
      max-width: 1200px;
      margin: 0 auto;
    }
    .footer-premium a {
      color: #9bb3e0;
      text-decoration: none;
      margin: 0 12px;
      font-size: 0.9rem;
    }
    .footer-premium a:hover { color: white; }
    hr {
      background: rgba(255,255,255,0.1);
      margin: 24px 0;
      border: none;
      height: 1px;
    }
    @media (max-width: 700px) {
      .navbar-premium { flex-direction: column; height: auto; padding: 16px; gap: 10px; }
      .nav-links a { margin: 0 1rem; font-size: 0.9rem; }
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <%- include("partials/nav") %>

  <!-- Hero Section -->
  <section class="hero">
    <h1>Welcome to EduManage Pro</h1>
    <p>The complete, modern, and easy-to-use School Management System trusted by hundreds of schools across India</p>
    <a href="/school/create" class="btn-primary">
      Create Your School Free
    </a>
  </section>

  <!-- Features Section -->
  <section class="features-section">
    <h2 class="section-title">Everything Your School Needs</h2>
    <p class="section-subtitle">Manage teachers, students, attendance, exams, results, and communication — all in one powerful platform</p>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">Teacher</div>
        <h3>Teacher Management</h3>
        <p>Add, assign subjects, track attendance, and manage teacher profiles with ease</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">Student</div>
        <h3>Student Records</h3>
        <p>Complete student profiles, class assignment, progress tracking, and parent communication</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">Clipboard</div>
        <h3>Attendance & Exams</h3>
        <p>Daily attendance marking, exam scheduling, result publishing, and report cards</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">Bullhorn</div>
        <h3>Instant Announcements</h3>
        <p>Send notices, homework, events, and alerts to parents and students instantly</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">Chart</div>
        <h3>Smart Reports</h3>
        <p>Beautiful dashboards with attendance trends, performance analytics, and insights</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">Mobile</div>
        <h3>Mobile Ready</h3>
        <p>Works perfectly on phones — teachers mark attendance, parents check results on the go</p>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="cta-section">
    <h2>Ready to Go Digital?</h2>
    <p>Join thousands of schools already saving time and reducing paperwork with EduManage.png</p>
    
    <div style="margin-top: 40px;">
      <a href="/school/create" class="btn-primary" style="margin: 0 16px; padding: 20px 56px; font-size: 20px;">
        Start Free Now
      </a>
      <a href="/about" class="btn-secondary" style="margin: 0 16px;">
        Learn More About Us
      </a>
    </div>
  </section>

  <!-- Footer -->
  <%- include("partials/footer") %>

  <script src="/scripts/nav.js"></script>
</body>
</html>
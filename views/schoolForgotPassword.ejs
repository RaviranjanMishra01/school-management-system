<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password — CoolManagement</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --primary-dark: #1557b0;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --card: #ffffff;
      --border: #e2e8f0;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 24px;
      --transition: all 0.4s ease;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f7ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: var(--text);
    }

    .forgot-card {
      width: 100%;
      max-width: 500px;
      background: var(--card);
      padding: 60px 50px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border: 1px solid rgba(26, 115, 232, 0.12);
      position: relative;
      overflow: hidden;
      animation: floatIn 0.8s ease-out;
    }

    .forgot-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 6px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo {
      width: 84px;
      height: 84px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      font-weight: bold;
      margin: 0 auto 32px;
      box-shadow: 0 12px 30px rgba(26, 115, 232, 0.3);
    }

    h2 {
      font-size: 34px;
      font-weight: 800;
      margin-bottom: 12px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .info {
      font-size: 16px;
      color: var(--text-light);
      margin-bottom: 36px;
      line-height: 1.6;
    }

    .error {
      background: #fee2e2;
      color: var(--danger);
      padding: 16px 20px;
      border-radius: 12px;
      margin-bottom: 28px;
      font-weight: 600;
      border-left: 4px solid var(--danger);
      animation: shake 0.5s ease;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-6px); }
      75% { transform: translateX(6px); }
    }

    form { display: grid; gap: 22px; }

    label {
      text-align: left;
      font-weight: 600;
      font-size: 15px;
      color: var(--text);
    }

    input[type="text"],
    input[type="email"] {
      width: 100%;
      padding: 18px 20px;
      border: 2px solid #e2e8f0;
      border-radius: 14px;
      font-size: 17px;
      background: #fafafa;
      transition: var(--transition);
    }

    input:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 5px rgba(26, 115, 232, 0.15);
    }

    /* FIXED: removed the extra opening brace */
    button {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 18px;
      border: none;
      border-radius: 14px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 10px 30px rgba(26, 115, 232, 0.3);
    }

    button:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(26, 115, 232, 0.4);
    }

    .back-link {
      margin-top: 32px;
      font-size: 15px;
    }

    .back-link a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      transition: var(--transition);
    }

    .back-link a:hover { text-decoration: underline; }

    @media (max-width: 480px) {
      .forgot-card { padding: 48px 32px; }
      h2 { font-size: 30px; }
    }
  </style>
</head>
<body>

  <div class="forgot-card">
    <div class="logo">CM</div>

    <h2>Forgot Password?</h2>
    <p class="info">
      No worries! Just enter your registered <strong>Email</strong> or <strong>CMS ID</strong><br>
      and we’ll send you a 6-digit OTP to reset your password.
    </p>

    <% if (message) { %>
      <div class="error"><%= message %></div>
    <% } %>

    <form action="/school/forgot-password" method="POST">
      <label for="input">Email or CMS ID</label>
      <input 
        type="text" 
        name="input" 
        id="input" 
        required 
        placeholder="e.g. principal@school.com or CMS12345"
        autocomplete="username"
      />

      <button type="submit">Send OTP</button>
    </form>

    <div class="back-link">
      <a href="/school/login">Back to Login</a>
    </div>
  </div>

  <script>
    document.getElementById('input').focus();
  </script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Teacher Dashboard — EduManage.png</title>

  <!-- Google Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #1e3a8a;       /* deep blue */
      --primary-light: #3b82f6;
      --primary-glow: #dbeafe;
      --secondary: #0f172a;
      --success: #10b981;
      --danger: #ef4444;
      --warning: #f59e0b;
      --info: #06b6d4;
      --gray-50: #f9fafb;
      --gray-100: #f1f5f9;
      --gray-200: #e2e8f0;
      --gray-600: #475569;
      --gray-700: #334155;
      --text-dark: #0f172a;
      --text-muted: #64748b;
      --bg-page: #f1f5f9;
      --card-bg: #ffffff;
      --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
      --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
      --shadow-lg: 0 20px 25px -5px rgb(0 0 0 / 0.08), 0 8px 10px -6px rgb(0 0 0 / 0.05);
      --shadow-xl: 0 25px 50px -12px rgb(0 0 0 / 0.15);
      --radius-lg: 28px;
      --radius-md: 20px;
      --radius-sm: 16px;
      --transition: all 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-page);
      color: var(--text-dark);
      line-height: 1.5;
      min-height: 100vh;
    }

    /* ========== SIDEBAR (glassmorphism premium) ========== */
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: 290px;
      background: rgba(15, 23, 42, 0.96);
      backdrop-filter: blur(16px);
      border-right: 1px solid rgba(255,255,255,0.1);
      color: #e2e8f0;
      padding: 32px 24px;
      z-index: 1050;
      transition: transform 0.3s ease;
      box-shadow: 10px 0 30px rgba(0,0,0,0.15);
      display: flex;
      flex-direction: column;
    }

    .logo {
      font-size: 1.9rem;
      font-weight: 800;
      background: linear-gradient(135deg, #fff, #94a3b8);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-align: center;
      margin-bottom: 40px;
      letter-spacing: -0.5px;
    }

    .user-info {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(4px);
      border-radius: var(--radius-sm);
      padding: 18px 16px;
      text-align: center;
      margin-bottom: 40px;
      border: 1px solid rgba(255,255,255,0.15);
    }

    .user-info h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: white;
      margin-bottom: 6px;
    }

    .user-info p {
      font-size: 0.8rem;
      opacity: 0.8;
    }

    .nav-menu {
      list-style: none;
      flex-grow: 1;
    }

    .nav-menu a {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 18px;
      color: #cbd5e6;
      text-decoration: none;
      border-radius: 14px;
      font-weight: 500;
      transition: var(--transition);
      margin-bottom: 8px;
    }

    .nav-menu a i {
      width: 24px;
      font-size: 1.2rem;
    }

    .nav-menu a:hover {
      background: rgba(59,130,246,0.25);
      color: white;
      transform: translateX(6px);
    }

    .logout {
      margin-top: auto;
    }
    .logout a {
      background: rgba(239,68,68,0.15);
      color: #fecaca;
    }
    .logout a:hover {
      background: #ef4444;
      color: white;
    }

    /* Mobile sidebar toggle button */
    .mobile-toggle {
      display: none;
      position: fixed;
      top: 20px;
      left: 20px;
      background: white;
      border: none;
      width: 48px;
      height: 48px;
      border-radius: 30px;
      box-shadow: var(--shadow-lg);
      z-index: 1060;
      cursor: pointer;
      color: var(--primary);
      font-size: 1.5rem;
      transition: var(--transition);
    }

    /* main content */
    .main-content {
      margin-left: 290px;
      padding: 40px 48px;
      transition: margin 0.3s;
    }

    /* header */
    .page-header {
      margin-bottom: 40px;
    }
    .page-header h1 {
      font-size: 2.2rem;
      font-weight: 800;
      background: linear-gradient(125deg, #0f2b3d, var(--primary-light));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.3px;
    }
    .page-header p {
      color: var(--text-muted);
      font-size: 1rem;
      margin-top: 8px;
    }

    /* Cards grid */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 28px;
      margin-bottom: 48px;
    }

    .card {
      background: var(--card-bg);
      border-radius: var(--radius-md);
      padding: 26px 28px;
      box-shadow: var(--shadow-md);
      transition: var(--transition);
      border: 1px solid var(--gray-200);
      margin-bottom: 1.2rem;
    }
    .card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-xl);
      border-color: var(--primary-glow);
    }
    .class-card {
      background: linear-gradient(145deg, #ffffff, #f8fafc);
      border-left: 5px solid var(--primary-light);
    }
    .card h3 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--primary);
    }
    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 20px;
    }

    /* buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.85rem;
      text-decoration: none;
      transition: var(--transition);
      border: none;
      cursor: pointer;
    }
    .btn-small {
      padding: 7px 14px;
      font-size: 0.75rem;
    }
    .btn-blue { background: var(--primary-light); color: white; box-shadow: 0 2px 6px rgba(59,130,246,0.3); }
    .btn-green { background: var(--success); color: white; }
    .btn-red { background: var(--danger); color: white; }
    .btn-dark-green { background: #059669; color: white; }
    .btn-gray { background: var(--gray-600); color: white; }
    .btn-disabled { background: #94a3b8; opacity: 0.6; cursor: not-allowed; }
    .btn:hover { transform: translateY(-2px); filter: brightness(1.02); box-shadow: 0 8px 18px rgba(0,0,0,0.1); }

    /* tables */
    .table-wrapper {
      overflow-x: auto;
      border-radius: var(--radius-sm);
      margin-top: 20px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: var(--radius-sm);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    th {
      background: var(--gray-100);
      color: var(--secondary);
      padding: 14px 18px;
      text-align: left;
      font-weight: 700;
      font-size: 0.85rem;
    }
    td {
      padding: 14px 18px;
      border-bottom: 1px solid var(--gray-200);
      vertical-align: middle;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fefce8; }

    .mini-input {
      padding: 8px 12px;
      border: 1px solid var(--gray-200);
      border-radius: 40px;
      font-size: 0.75rem;
      width: 130px;
    }
    .badge {
      padding: 4px 12px;
      border-radius: 40px;
      font-size: 0.7rem;
      font-weight: 600;
      display: inline-block;
    }
    .badge-success { background: #d1fae5; color: #065f46; }
    .badge-danger { background: #fee2e2; color: #991b1b; }
    .no-data {
      text-align: center;
      padding: 48px 20px;
      color: var(--text-muted);
      font-style: italic;
      background: #fafcff;
      border-radius: var(--radius-sm);
    }
    .list {
      list-style: none;
      padding: 8px 0;
    }
    .list li {
      padding: 12px 0;
      border-bottom: 1px solid var(--gray-200);
      font-weight: 500;
    }

    /* responsiveness */
    @media (max-width: 950px) {
      .sidebar {
        transform: translateX(-100%);
      }
      .sidebar.open {
        transform: translateX(0);
      }
      .main-content {
        margin-left: 0;
        padding: 28px 24px;
      }
      .mobile-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 550px) {
      .actions { flex-direction: column; align-items: stretch; }
      .btn { justify-content: center; }
      td { display: flex; flex-wrap: wrap; gap: 8px; justify-content: space-between; align-items: center; }
      td::before { content: attr(data-label); font-weight: 700; width: 40%; }
      .student-table thead { display: none; }
      .student-table tr { display: block; margin-bottom: 20px; border: 1px solid var(--gray-200); border-radius: 20px; padding: 12px; }
      .student-table td { display: flex; border: none; padding: 8px 12px; }
    }
  </style>
</head>
<body>

  <!-- mobile toggle button -->
  <button class="mobile-toggle" id="mobileSidebarToggle">
    <i class="fas fa-bars"></i>
  </button>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="logo">
      <i class="fas fa-graduation-cap"></i> CM
    </div>
    <div class="user-info">
      <h3><%= teacher.name %></h3>
      <p>Teacher Account</p>
      <i class="fas fa-chalkboard-user" style="margin-top: 8px; opacity: 0.7;"></i>
    </div>
    <ul class="nav-menu">
      <li><a href="/teacher/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
      <li class="logout"><a href="/teacher/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <div class="page-header">
      <h1>✨ Welcome back, <%= teacher.name %>!</h1>
      <p>Manage your classes, students, attendance and subject assignments seamlessly</p>
    </div>

    <!-- Class Teacher Cards (Primary responsibility) -->
    <% if (classTeacherOf && classTeacherOf.length > 0) { %>
      <div class="grid">
        <% classTeacherOf.forEach(c => { %>
          <div class="card class-card">
            <h3><i class="fas fa-chalkboard"></i> Class <%= c.className %></h3>
            <div class="actions">
              <a href="/teacher/class/<%= c._id %>/assign-subject-teachers" class="btn btn-blue btn-small">
                <i class="fas fa-user-plus"></i> Assign Teachers
              </a>
              <a href="/teacher/class/<%= c._id %>/create-student" class="btn btn-green btn-small">
                <i class="fas fa-user-graduate"></i> Add Student
              </a>
              <% if (todayTakenForClasses && todayTakenForClasses.includes(c._id.toString())) { %>
                <span class="btn btn-disabled btn-small" disabled><i class="fas fa-check-circle"></i> Attendance Taken</span>
                <span class="badge badge-success"><i class="fas fa-calendar-check"></i> Today done</span>
              <% } else { %>
                <a href="/teacher/class/<%= c._id %>/attendance" class="btn btn-blue btn-small">
                  <i class="fas fa-clipboard-list"></i> Take Attendance
                </a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Assigned Classes (as subject teacher) -->
    <div class="card">
      <h3><i class="fas fa-book-open"></i> Your Assigned Classes</h3>
      <% if (assignedClasses && assignedClasses.length === 0) { %>
        <div class="no-data">📌 You are not assigned to any class as a subject teacher yet.</div>
      <% } else { %>
        <div class="list">
          <% assignedClasses.forEach(cls => { %>
            <li><strong><i class="fas fa-school"></i> <%= cls.className %></strong>  <span class="badge badge-success" style="margin-left: 8px;">Subject Teacher</span></li>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Students Table (only if teacher is class teacher) -->
    <% if (students && students.length > 0 && classTeacherOf && classTeacherOf.length >= 1) { %>
      <div class="card">
        <h3><i class="fas fa-users"></i> Students in Your Classes</h3>
        <div class="table-wrapper">
          <table class="student-table">
            <thead>
              <tr>
                <th>Student Name</th><th>ID</th><th>Email</th><th>Status</th><th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% students.forEach(s => { 
                const remaining = s.remainingDays || 0;
              %>
                <tr>
                  <td data-label="Name"><strong><%= s.name %></strong></td>
                  <td data-label="ID"><code style="background:#f1f5f9; padding:2px 6px; border-radius: 12px;"><%= s._id.toString().slice(-6) %></code></td>
                  <td data-label="Email"><%= s.email %></td>
                  <td data-label="Status">
                    <% if (remaining > 0) { %>
                      <span class="badge badge-danger"><i class="fas fa-ban"></i> Suspended (<%= remaining %>d)</span>
                    <% } else { %>
                      <span class="badge badge-success"><i class="fas fa-check-circle"></i> Active</span>
                    <% } %>
                  </td>
                  <td data-label="Actions">
                    <div class="actions" style="gap: 8px; margin-top:0;">
                      <form action="/teacher/student/update-email/<%= s._id %>" method="POST" style="display: inline-flex; gap: 6px; align-items:center;">
                        <input type="email" name="email" placeholder="New email" required class="mini-input"/>
                        <button class="btn btn-small btn-blue" type="submit"><i class="fas fa-sync-alt"></i> Update</button>
                      </form>
                      <a class="btn btn-small btn-green" href="mailto:<%= s.email %>"><i class="fas fa-envelope"></i> Mail</a>
                      <% if (remaining > 0) { %>
                        <form action="/teacher/student/unsuspend/<%= s._id %>" method="POST" style="display:inline">
                          <button class="btn btn-small btn-dark-green"><i class="fas fa-play-circle"></i> Unsuspend</button>
                        </form>
                      <% } else { %>
                        <form action="/teacher/student/suspend/<%= s._id %>" method="POST" style="display: inline-flex; gap: 6px; align-items:center;">
                          <input type="number" name="days" min="1" placeholder="Days" required class="mini-input" style="width:80px;"/>
                          <button class="btn btn-small btn-red"><i class="fas fa-pause-circle"></i> Suspend</button>
                        </form>
                      <% } %>
                      <form action="/teacher/student/delete/<%= s._id %>" method="POST" onsubmit="return confirm('⚠️ Permanently delete this student?');" style="display:inline">
                        <button class="btn btn-small btn-gray"><i class="fas fa-trash-alt"></i> Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <!-- Subjects & Assigned Teachers Table -->
    <div class="card">
      <h3><i class="fas fa-microscope"></i> Subjects & Teachers</h3>
      <% if (subjectsOfClasses && subjectsOfClasses.length > 0) { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr><th>Class</th><th>Subject</th><th>Assigned Teacher(s)</th></tr>
            </thead>
            <tbody>
              <% subjectsOfClasses.forEach(subj => { %>
                <tr>
                  <td data-label="Class"><%= subj.classId?.className || '—' %></td>
                  <td data-label="Subject"><%= subj.subjectName %></td>
                  <td data-label="Teachers">
                    <% if (subj.subjectTeachers && subj.subjectTeachers.length) { %>
                      <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                        <% subj.subjectTeachers.forEach(teacher => { %>
                          <span class="badge badge-success" style="background:#e0e7ff; color:#1e40af;"><i class="fas fa-user-check"></i> <%= teacher.name %></span>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <span class="badge" style="background:#f1f5f9;">Not assigned</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="no-data"><i class="fas fa-folder-open"></i> No subjects have been configured for your classes yet.</div>
      <% } %>
      <div style="margin-top: 20px; font-size: 0.75rem; color: var(--gray-600);">
        <i class="fas fa-info-circle"></i> Class teachers can assign subject teachers via class card.
      </div>
    </div>
  </main>

  <script>
    // Sidebar toggle for mobile
    const toggleBtn = document.getElementById('mobileSidebarToggle');
    const sidebar = document.getElementById('sidebar');
    if (toggleBtn && sidebar) {
      toggleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        sidebar.classList.toggle('open');
      });
      // close sidebar when clicking outside on mobile (optional)
      document.addEventListener('click', (event) => {
        if (window.innerWidth <= 950 && sidebar.classList.contains('open')) {
          if (!sidebar.contains(event.target) && event.target !== toggleBtn && !toggleBtn.contains(event.target)) {
            sidebar.classList.remove('open');
          }
        }
      });
    }

    // responsive table labeling for small devices
    function applyDataLabels() {
      if (window.innerWidth <= 550) {
        document.querySelectorAll('.student-table tbody tr').forEach(row => {
          const cells = row.querySelectorAll('td');
          const headers = ['Name', 'ID', 'Email', 'Status', 'Actions'];
          cells.forEach((cell, idx) => {
            if (headers[idx]) cell.setAttribute('data-label', headers[idx]);
          });
        });
        // subjects table labels
        document.querySelectorAll('.table-wrapper table tbody tr').forEach(row => {
          const cells = row.querySelectorAll('td');
          if (cells.length === 3) {
            cells[0].setAttribute('data-label', 'Class');
            cells[1].setAttribute('data-label', 'Subject');
            cells[2].setAttribute('data-label', 'Assigned Teacher(s)');
          }
        });
      } else {
        document.querySelectorAll('td').forEach(td => td.removeAttribute('data-label'));
      }
    }
    applyDataLabels();
    window.addEventListener('resize', applyDataLabels);
  </script>
  <style>
    /* extra polish for tables on mobile */
    @media (max-width: 550px) {
      .table-wrapper table, .table-wrapper thead, .table-wrapper tbody, .table-wrapper th, .table-wrapper td, .table-wrapper tr {
        display: block;
      }
      .table-wrapper thead tr {
        position: absolute;
        top: -9999px;
        left: -9999px;
      }
      .table-wrapper tr {
        margin-bottom: 20px;
        border: 1px solid var(--gray-200);
        border-radius: 20px;
        background: white;
        padding: 12px;
      }
      .table-wrapper td {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid #edf2f7;
        padding: 12px;
      }
      .table-wrapper td:last-child {
        border-bottom: none;
      }
      .table-wrapper td::before {
        content: attr(data-label);
        font-weight: 700;
        width: 40%;
        color: #1e293b;
      }
      .actions {
        justify-content: flex-start;
      }
    }
  </style>
</body>
</html>
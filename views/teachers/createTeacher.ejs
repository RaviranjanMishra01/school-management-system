<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Teacher — EduManage.png</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --success: #10b981;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --card: #ffffff;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 26px;
      --transition: all 0.4s ease;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f7ff 100%);
      min-height: 100vh;
      padding: 20px;
      color: var(--text);
    }

    .create-card {
      max-width: 560px;
      margin: 40px auto;
      background: var(--card);
      padding: 60px 52px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid rgba(26, 115, 232, 0.12);
      position: relative;
      overflow: hidden;
      animation: floatIn 0.9s ease-out;
    }

    .create-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 7px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo {
      width: 92px;
      height: 92px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
      font-weight: 900;
      margin: 0 auto 34px;
      box-shadow: 0 16px 38px rgba(26, 115, 232, 0.35);
      letter-spacing: -2px;
    }

    h2 {
      font-size: 36px;
      font-weight: 800;
      text-align: center;
      margin-bottom: 12px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      text-align: center;
      color: var(--text-light);
      font-size: 17px;
      margin-bottom: 40px;
    }

    .message, .error {
      padding: 16px 20px;
      border-radius: 14px;
      margin-bottom: 28px;
      font-weight: 600;
      text-align: center;
      animation: shake 0.6s ease-in-out;
    }

    .message {
      background: #d1fae5;
      color: #065f46;
      border-left: 5px solid var(--success);
    }

    .error {
      background: #fee2e2;
      color: #991b1b;
      border-left: 5px solid var(--danger);
    }

    @keyframes shake {
      0%,100% { transform: translateX(0); }
      20% { transform: translateX(-8px); }
      40% { transform: translateX(8px); }
      60% { transform: translateX(-6px); }
      80% { transform: translateX(6px); }
    }

    form {
      display: grid;
      gap: 22px;
    }

    label {
      font-weight: 600;
      font-size: 15px;
      color: var(--text);
    }

    input, select {
      width: 100%;
      padding: 18px 20px;
      border: 2px solid #e2e8f0;
      border-radius: 14px;
      font-size: 17px;
      background: #fafafa;
      transition: var(--transition);
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 5px rgba(26, 115, 232, 0.15);
    }

    button {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 19px;
      border: none;
      border-radius: 16px;
      font-size: 18.5px;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 12px 32px rgba(26, 115, 232, 0.32);
    }

    button:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 45px rgba(26, 115, 232, 0.42);
    }

    .back-link {
      text-align: center;
      margin-top: 32px;
    }

    .back-link a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      font-size: 16px;
      transition: var(--transition);
    }

    .back-link a:hover {
      text-decoration: underline;
    }

    @media (max-width: 480px) {
      .create-card { padding: 48px 32px; }
      h2 { font-size: 30px; }
    }
  </style>
</head>
<body>

  <div class="create-card">
    <div class="logo">CM</div>

    <h2>Create New Teacher</h2>
    <p class="subtitle">Add a new teacher to your school management system</p>

    <% if (message) { %>
      <div class="<%= message.toLowerCase().includes('error') || message.toLowerCase().includes('failed') ? 'error' : 'message' %>">
        <%= message %>
      </div>
    <% } %>

    <form method="POST" action="/school/teachers/create">
      <label for="name">Full Name</label>
      <input type="text" name="name" id="name" placeholder="Enter teacher full name" required autocomplete="name">

      <label for="email">Email Address</label>
      <input type="email" name="email" id="email" placeholder="teacher@school.com" required autocomplete="email">

      <label for="phone">Phone Number</label>
      <input type="text" name="phone" id="phone" placeholder="+91 98765 43210" required>

      <label for="subject">Subject</label>
      <select name="subject" id="subject" required>
        <option value="">-- Select Subject --</option>
        <option value="Math">Math</option>
        <option value="English">English</option>
        <option value="Science">Science</option>
        <option value="History">History</option>
        <option value="Geography">Geography</option>
        <option value="Hindi">Hindi</option>
        <option value="Sanskrit">Sanskrit</option>
        <option value="Physics">Physics</option>
        <option value="Chemistry">Chemistry</option>
        <option value="Biology">Biology</option>
        <option value="Computer">Computer</option>
        <option value="Music">Music</option>
        <option value="Games">Games / Physical Education</option>
        <option value="Arts">Arts & Crafts</option>
      </select>

      <label for="salary">Monthly Salary (₹)</label>
      <input type="number" name="salary" id="salary" placeholder="e.g. 45000" min="10000" max="100000" required>

      <label for="password">Default Password</label>
      <input type="password" name="password" id="password" placeholder="Set a secure password" required minlength="6">

      <button type="submit">
        Create Teacher Account
      </button>
    </form>

    <div class="back-link">
      <a href="/school/dashboard">Back to Dashboard</a>
    </div>
  </div>

  <script>
    // Auto-focus first field
    document.getElementById('name')?.focus();
  </script>

</body>
</html>
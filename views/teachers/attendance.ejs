<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Take Attendance — EduManage.png</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --success: #10b981;
      --danger: #ef4444;
      --warning: #f59e0b;
      --text: #1e293b;
      --text-light: #64748b;
      --card: #ffffff;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 26px;
      --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f7ff 100%);
      min-height: 100vh;
      padding: 20px;
      color: var(--text);
    }

    .attendance-card {
      max-width: 900px;
      margin: 30px auto;
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid rgba(26, 115, 232, 0.12);
      position: relative;
      overflow: hidden;
      animation: floatIn 0.9s ease-out;
    }

    .attendance-card::before {
      content: '';
      position: absolute;
      /* prog top: 0; left: 0; right: 0; */
      height: 8px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .header {
      text-align: center;
      padding: 40px 30px 20px;
      background: linear-gradient(135deg, rgba(26,115,232,0.06), rgba(66,133,244,0.04));
    }

    .logo {
      width: 90px;
      height: 90px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 38px;
      font-weight: 900;
      margin: 0 auto 24px;
      box-shadow: 0 16px 38px rgba(26, 115, 232, 0.35);
    }

    h2 {
      font-size: 38px;
      font-weight: 800;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
    }

    .class-info {
      font-size: 20px;
      font-weight: 600;
      color: var(--primary);
      margin: 16px 0;
    }

    .date-info {
      font-size: 17px;
      color: var(--text-light);
      font-weight: 500;
    }

    .warning-note {
      background: #fff8c5;
      color: #925000;
      padding: 14px 20px;
      border-radius: 14px;
      font-weight: 600;
      margin: 20px auto;
      max-width: 600px;
      border-left: 5px solid var(--warning);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 20px;
      margin: 32px 40px;
    }

    .stat-card {
      background: white;
      padding: 24px;
      border-radius: 20px;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      border: 2px solid #e2e8f0;
      transition: var(--transition);
    }

    .stat-card.present { border-color: var(--success); }
    .stat-card.absent { border-color: var(--danger); }
    .stat-card.total { border-color: var(--primary); }

    .stat-number {
      font-size: 42px;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .present .stat-number { color: var(--success); }
    .absent .stat-number { color: var(--danger); }
    .total .stat-number { color: var(--primary); }

    .mark-all-btn {
      display: block;
      margin: 24px auto;
      background: linear-gradient(135deg, var(--success), #34d399);
      color: white;
      padding: 16px 36px;
      border: none;
      border-radius: 16px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 10px 30px rgba(16, 185, 129, 0.3);
      transition: var(--transition);
    }

    .mark-all-btn:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(16, 185, 129, 0.4);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
      background: white;
    }

    th {
      background: var(--primary);
      color: white;
      padding: 20px;
      text-align: left;
      font-weight: 600;
      font-size: 16px;
    }

    td {
      padding: 18px 20px;
      border-bottom: 1px solid #e2e8f0;
    }

    tr:hover {
      background: #f8faff;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .attendance-options {
      display: flex;
      justify-content: center;
      gap: 20px;
    }

    .radio-wrapper {
      position: relative;
    }

    input[type="radio"] {
      position: absolute;
      opacity: 0;
      cursor: pointer;
    }

    .radio-label {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      border-radius: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      min-width: 120px;
      justify-content: center;
    }

    .present-label {
      background: #d1fae5;
      color: #065f46;
      border: 2px solid #a7f3d0;
    }

    .absent-label {
      background: #fee2e2;
      color: #991b1b;
      border: 2px solid #fca5a5;
    }

    input[type="radio"]:checked + .present-label {
      background: var(--success);
      color: white;
      transform: scale(1.08);
      box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
    }

    input[type="radio"]:checked + .absent-label {
      background: var(--danger);
      color: white;
      transform: scale(1.08);
      box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
    }

    .submit-section {
      text-align: center;
      padding: 40px 30px;
      background: #f8faff;
    }

    .submit-btn {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 20px 60px;
      border: none;
      border-radius: 18px;
      font-size: 20px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 15px 40px rgba(26, 115, 232, 0.35);
      transition: var(--transition);
    }

    .submit-btn:hover {
      transform: translateY(-6px);
      box-shadow: 0 25px 50px rgba(26, 115, 232, 0.45);
    }

    @media (max-width: 768px) {
      .attendance-card { margin: 10px; padding: 20px; }
      .stats-grid { grid-template-columns: 1fr; margin: 20px; }
      .attendance-options { gap: 12px; }
      .radio-label { padding: 12px 20px; font-size: 14px; }
      h2 { font-size: 30px; }
    }
  </style>
</head>
<body>

  <div class="attendance-card">
    <div class="header">
      <div class="logo">CM</div>
      <h2>Take Attendance</h2>
      <div class="class-info">Class ID: <strong><%= classId %></strong></div>
      <div class="date-info">
        <%= new Date(today).toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      </div>
      <% if (attendanceRecord) { %>
        <div class="warning-note">
          Attendance already recorded today — You are now in edit mode
        </div>
      <% } %>
    </div>

    <form id="attendanceForm" action="/teacher/class/<%= classId %>/attendance" method="POST">
      
      <div class="stats-grid">
        <div class="stat-card present">
          <div class="stat-number" id="presentCount">0</div>
          <div>Present</div>
        </div>
        <div class="stat-card absent">
          <div class="stat-number" id="absentCount">0</div>
          <div>Absent</div>
        </div>
        <div class="stat-card total">
          <div class="stat-number"><%= students.length %></div>
          <div>Total Students</div>
        </div>
      </div>

      <button type="button" class="mark-all-btn" onclick="markAllPresent()">
        Mark All Present
      </button>

      <table>
        <thead>
          <tr>
            <th style="width: 60px;">#</th>
            <th>Student Name</th>
            <th style="text-align: center;">Mark Attendance</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach((s, index) => { %>
            <% 
              const record = attendanceRecord?.attendance.find(a => a.studentRef.toString() === s._id.toString());
              const status = record ? record.status : "P";
            %>
            <tr>
              <td><%= index + 1 %></td>
              <td><strong><%= s.name %></strong></td>
              <td class="attendance-options">
                <div class="radio-wrapper">
                  <input type="radio" name="attendance[<%= s._id %>]" value="P" id="p_<%= s._id %>" <%= status === "P" ? "checked" : "" %> required>
                  <label for="p_<%= s._id %>" class="radio-label present-label">Present</label>
                </div>
                <div class="radio-wrapper">
                  <input type="radio" name="attendance[<%= s._id %>]" value="A" id="a_<%= s._id %>" <%= status === "A" ? "checked" : "" %>>
                  <label for="a_<%= s._id %>" class="radio-label absent-label">Absent</label>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="submit-section">
        <button type="submit" class="submit-btn">
          Save Attendance
        </button>
      </div>
    </form>
  </div>

  <script>
    function updateStats() {
      const presents = document.querySelectorAll('input[value="P"]:checked').length;
      const absents = document.querySelectorAll('input[value="A"]:checked').length;

      document.getElementById('presentCount').textContent = presents;
      document.getElementById('absentCount').textContent = absents;
    }

    function markAllPresent() {
      document.querySelectorAll('input[value="P"]').forEach(radio => {
        radio.checked = true;
      });
      updateStats();
    }

    document.querySelectorAll('input[type="radio"]').forEach(radio => {
      radio.addEventListener('change', updateStats);
    });

    updateStats();
  </script>
</body>
</html>
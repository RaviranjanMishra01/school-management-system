<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>School Dashboard — CoolManagement</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/styles/footer.css" />

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --primary-dark: #1557b0;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --bg: #f8fafc;
      --card: #ffffff;
      --border: #e2e8f0;
      --shadow: 0 10px 30px rgba(0,0,0,0.08);
      --radius: 18px;
      --transition: all 0.3s ease;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    /* Navbar - Premium Fixed */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      background: rgba(26, 115, 232, 0.98);
      backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 1000;
      box-shadow: 0 4px 20px rgba(26, 115, 232, 0.2);
    }

    .nav-brand {
      font-size: 22px;
      font-weight: 800;
      color: white;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-brand i { font-size: 26px; }

    .nav-links {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .nav-links a, .dropbtn {
      color: white;
      text-decoration: none;
      padding: 10px 16px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 15px;
      transition: var(--transition);
    }

    .nav-links a:hover, .dropbtn:hover {
      background: rgba(255,255,255,0.15);
    }

    .dropdown {
      position: relative;
    }

    .dropdown-content {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      background: white;
      min-width: 220px;
      border-radius: 14px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.15);
      overflow: hidden;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      margin-top: 10px;
    }

    .dropdown:hover .dropdown-content {
      opacity: 1;
      visibility: visible;
      margin-top: 6px;
    }

    .dropdown-content a {
      display: block;
      padding: 14px 20px;
      color: var(--text);
      font-weight: 500;
      transition: var(--transition);
    }

    .dropdown-content a:hover {
      background: #f1f5f9;
      color: var(--primary);
    }

    .menu-toggle { display: none; font-size: 24px; color: white; cursor: pointer; }

    /* Main Content */
    .container {
      max-width: 1280px;
      margin: 100px auto 40px;
      padding: 0 24px;
    }

    .page-title {
      font-size: 36px;
      font-weight: 800;
      margin-bottom: 16px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
      color: var(--text-light);
      font-size: 18px;
      margin-bottom: 40px;
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px;
      margin-bottom: 48px;
    }

    .stat-card {
      background: var(--card);
      padding: 28px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border: 1px solid var(--border);
      transition: var(--transition);
    }

    .stat-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(26,115,232,0.15);
    }

    .stat-icon {
      font-size: 42px;
      margin-bottom: 16px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .stat-value {
      font-size: 32px;
      font-weight: 800;
      color: var(--text);
    }

    .stat-label {
      color: var(--text-light);
      font-size: 15px;
      margin-top: 8px;
    }

    /* Tables */
    .table-container {
      background: var(--card);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      margin-bottom: 40px;
      border: 1px solid var(--border);
    }

    .table-header {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 20px 28px;
      font-size: 20px;
      font-weight: 700;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .search-info {
      font-size: 14px;
      opacity: 0.9;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th {
      background: #f8fafc;
      padding: 16px;
      text-align: left;
      font-weight: 600;
      color: var(--text);
      border-bottom: 2px solid var(--border);
    }

    td {
      padding: 16px;
      border-bottom: 1px solid var(--border);
    }

    tr:hover {
      background: #f8faff;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 8px 14px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: var(--transition);
    }

    .btn-success { background: var(--success); color: white; }
    .btn-warning { background: var(--warning); color: white; }
    .btn-danger { background: var(--danger); color: white; }
    .btn-primary { background: var(--primary); color: white; }

    .btn:hover { transform: translateY(-2px); opacity: 0.9; }

    .alert {
      padding: 16px 24px;
      border-radius: 12px;
      background: #fef3c7;
      color: #92400e;
      font-weight: 600;
      margin-bottom: 24px;
      border-left: 5px solid #f59e0b;
    }

    /* Responsive */
    @media (max-width: 992px) {
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .navbar { padding: 14px 20px; }
      .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--primary); flex-direction: column; }
      .nav-links.show { display: flex; }
      .menu-toggle { display: block; }
      .page-title { font-size: 30px; }
      table, thead, tbody, th, td, tr { display: block; }
      thead tr { position: absolute; top: -9999px; left: -9999px; }
      tr { border: 1px solid var(--border); border-radius: 12px; margin-bottom: 16px; padding: 12px; }
      td { border: none; position: relative; padding-left: 50%; }
      td:before { content: attr(data-label); position: absolute; left: 16px; font-weight: 600; }
    }
  </style>
</head>
<body>

  <!-- Premium Navbar -->
  <nav class="navbar">
    <div class="nav-brand">
      CoolManagement
    </div>
    <span class="menu-toggle" onclick="document.getElementById('navLinks').classList.toggle('show')">Menu</span>
    <div class="nav-links" id="navLinks">
      <a href="/school/dashboard">Dashboard</a>
      
      <div class="dropdown">
        <button class="dropbtn">Teachers</button>
        <div class="dropdown-content">
          <a href="/school/teachers/create">Create Teacher</a>
          <a href="/teacher/login">Teacher Login</a>
        </div>
      </div>

      <div class="dropdown">
        <button class="dropbtn">Classes</button>
        <div class="dropdown-content">
          <a href="/school/classes/create">Add New Class</a>
        </div>
      </div>

      <a href="/school/logout">Logout</a>
    </div>
  </nav>

  <div class="container">

    <h1 class="page-title">School Dashboard</h1>
    <p class="page-subtitle">Welcome back! Here's everything you need to manage your school.</p>

    <!-- Alert Message -->
    <% if (typeof msg !== 'undefined' && msg) { %>
      <div class="alert"><%= msg %></div>
    <% } %>

    <!-- Stats Overview -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">Teacher</div>
        <div class="stat-value"><%= totalTeachers %></div>
        <div class="stat-label">Total Teachers</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">School</div>
        <div class="stat-value"><%= totalClasses %></div>
        <div class="stat-label">Active Classes</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">Ban</div>
        <div class="stat-value"><%= suspendedCount %></div>
        <div class="stat-label">Suspended Teachers</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">Chart</div>
        <div class="stat-value"><%= avgAttendance %>%</div>
        <div class="stat-label">Avg. Attendance</div>
      </div>
    </div>

    <!-- Teachers Table -->
    <div class="table-container">
      <div class="table-header">
        <span>Teachers</span>
        <span class="search-info">Search: "<%= q || 'None' %>" • Page <%= teacherPage %> of <%= teacherTotalPages %></span>
      </div>
      <% if (teachers.length === 0) { %>
        <p style="padding: 32px; text-align: center; color: var(--text-light);">No teachers found.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>ID</th>
              <th>Phone</th>
              <th>Email</th>
              <th>Suspend Days</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% teachers.forEach(t => {
              const today = new Date();
              const remainingDays = t.suspendedUntil && t.suspendedUntil > today 
                                    ? Math.ceil((t.suspendedUntil - today) / (1000*60*60*24))
                                    : 0;
            %>
            <tr>
              <td data-label="Name"><%= t.name %></td>
              <td data-label="ID"><%= t._id %></td>
              <td data-label="Phone"><%= t.phone %></td>
              <td data-label="Email"><%= t.email %></td>
              <td data-label="Suspended">
                <strong><%= remainingDays > 0 ? remainingDays + ' days' : 'Active' %></strong>
              </td>
              <td data-label="Actions" class="actions">
                <% if (remainingDays > 0) { %>
                  <form method="POST" action="/school/teachers/unsuspend/<%= t._id %>" style="display:inline">
                    <button type="submit" class="btn btn-success">Unsuspend</button>
                  </form>
                <% } else { %>
                  <form method="POST" action="/school/teachers/suspend/<%= t._id %>" style="display:inline">
                    <input type="number" name="days" placeholder="Days" min="1" required style="width:70px;padding:8px;border-radius:8px;border:1px solid #ccc;" />
                    <button type="submit" class="btn btn-warning">Suspend</button>
                  </form>
                <% } %>
                <form method="POST" action="/school/teachers/delete/<%= t._id %>" style="display:inline">
                  <button type="submit" onclick="return confirm('Permanently delete this teacher?')" class="btn btn-danger">Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <!-- Classes Table -->
    <div class="table-container">
      <div class="table-header">
        <span>Classes</span>
        <span class="search-info">Search: "<%= cq || 'None' %>" • Page <%= classPage %> of <%= classTotalPages %></span>
      </div>
      <% if (classes.length === 0) { %>
        <p style="padding: 32px; text-align: center; color: var(--text-light);">No classes found.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Class Name</th>
              <th>Teacher</th>
              <th>Subjects</th>
              <th>Students</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% classes.forEach(c => { %>
            <tr>
              <td data-label="Class"><%= c.className %></td>
              <td data-label="Teacher"><%= c.classTeacherName || 'Not Assigned' %></td>
              <td data-label="Subjects"><%= (c.subjects && c.subjects.length) ? c.subjects.join(", ") : "—" %></td>
              <td data-label="Students"><%= c.totalStudents %></td>
              <td data-label="Actions" class="actions">
                <% if (c.isActive) { %>
                  <a href="/school/classes/deactivate/<%= c._id %>" class="btn btn-warning">Deactivate</a>
                <% } else { %>
                  <a href="/school/classes/activate/<%= c._id %>" class="btn btn-success">Activate</a>
                <% } %>
                <a href="/school/classes/edit/<%= c._id %>" class="btn btn-primary">Edit</a>
                <a href="/school/classes/delete/<%= c._id %>" onclick="return confirm('Delete this class permanently?')" class="btn btn-danger">Delete</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

  </div>

  <!-- Footer -->
  <%- include("partials/footer") %>

</body>
</html>
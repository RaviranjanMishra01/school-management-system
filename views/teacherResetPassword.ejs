<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Teacher Reset Password — CoolManagement</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --card: #ffffff;
      --border: #e2e8f0;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 24px;
      --transition: all 0.4s ease;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f7ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: var(--text);
    }

    .reset-card {
      width: 100%;
      max-width: 500px;
      background: var(--card);
      padding: 60px 50px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border: 1px solid rgba(26, 115, 232, 0.12);
      position: relative;
      overflow: hidden;
      animation: floatIn 0.8s ease-out;
    }

    .reset-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 6px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo {
      width: 84px;
      height: 84px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      font-weight: bold;
      margin: 0 auto 32px;
      box-shadow: 0 12px 30px rgba(26, 115, 232, 0.3);
    }

    h2 {
      font-size: 34px;
      font-weight: 800;
      margin-bottom: 12px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .info {
      font-size: 16px;
      color: var(--text-light);
      margin-bottom: 36px;
      line-height: 1.6;
    }

    .error {
      background: #fee2e2;
      color: var(--danger);
      padding: 16px 20px;
      border-radius: 12px;
      margin-bottom: 28778;
      font-weight: 600;
      border-left: 4px solid var(--danger);
      animation: shake 0.5s ease;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-6px); }
      75% { transform: translateX(6px); }
    }

    form { position: relative; display: grid; gap: 20px; }

    label {
      text-align: left;
      font-weight: 600;
      font-size: 15px;
      color: var(--text);
    }

    .password-wrapper {
      position: relative;
    }

    input[type="password"],
    input[type="text"] {
      width: 100%;
      padding: 18px 50px 18px 20px;
      border: 2px solid #e2e8f0;
      border-radius: 14px;
      font-size: 17px;
      background: #fafafa;
      transition: var(--transition);
    }

    input:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 5px rgba(26, 115, 232, 0.15);
    }

    .toggle-password {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: var(--text-light);
      font-size: 18px;
      transition: var(--transition);
    }

    .toggle-password:hover { color: var(--primary); }

    /* Strength Meter */
    .strength-meter {
      height: 6px;
      border-radius: 3px;
      background: #e2e8f0;
      overflow: hidden;
      margin-top: 10px;
    }

    .strength-fill {
      height: 100%;
      width: 0%;
      transition: all 0.4s ease;
      border-radius: 3px;
    }

    .strength-text {
      margin-top: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--text-light);
    }

    .weak { background: var(--danger); }
    .fair { background: var(--warning); }
    .good { background: #60a5fa; }
    .strong { background: var(--success); }

    button {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 18px;
      border: none;
      border-radius: 14px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 10px 30px rgba(26, 115, 232, 0.3);
      margin-top: 10px;
    }

    button:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(26, 115, 232, 0.4);
    }

    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .back-link {
      margin-top: 32px;
      font-size: 15px;
    }

    .back-link a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
    }

    .back-link a:hover { text-decoration: underline; }

    @media (max-width: 480px) {
      .reset-card { padding: 48px 32px; }
      h2 { font-size: 30px; }
    }
  </style>
</head>
<body>

  <div class="reset-card">
    <div class="logo">CM</div>

    <h2>Teacher Password Reset</h2>
    <p class="info">
      Create a strong new password for your teacher account<br>
      <strong><%= identifier %></strong>
    </p>

    <% if (message) { %>
      <div class="error"><%= message %></div>
    <% } %>

    <form action="/teacher/forgot-password/reset" method="POST" id="resetForm">
      <input type="hidden" name="identifier" value="<%= identifier %>">

      <label for="newPassword">New Password</label>
      <div class="password-wrapper">
        <input 
          type="password" 
          name="newPassword" 
          id="newPassword" 
          required 
          minlength="8"
          placeholder="Enter strong password"
          autocomplete="new-password"
        />
        <i class="fas fa-eye toggle-password" id="togglePassword"></i>
      </div>

      <div class="strength-meter">
        <div class="strength-fill" id="strengthFill"></div>
      </div>
      <div  <div class="strength-text" id="strengthText">Enter a strong password</div>

      <button type="submit" id="submitBtn" disabled>
        Reset Password
      </button>
    </form>

    <div class="back-link">
      <a href="/teacher/login">Back to Teacher Login</a>
    </div>
  </div>

  <script>
    const passwordInput = document.getElementById('newPassword');
    const togglePassword = document.getElementById('togglePassword');
    const strengthFill = document.getElementById('strengthFill');
    const strengthText = document.getElementById('strengthText');
    const submitBtn = document.getElementById('submitBtn');

    // Toggle Show/Hide
    togglePassword.addEventListener('click', () => {
      const type = passwordInput.type === 'password' ? 'text' : 'password';
      passwordInput.type = type;
      togglePassword.classList.toggle('fa-eye');
      togglePassword.classList.toggle('fa-eye-slash');
    });

    // Strength Checker
    passwordInput.addEventListener('input', () => {
      const val = passwordInput.value;
      let strength = 0;

      if (val.length >= 8) strength++;
      if (val.match(/[a-z]/) && val.match(/[A-Z]/)) strength++;
      if (val.match(/[0-9]/)) strength++;
      if (val.match(/[^a-zA-Z0-9]/)) strength++;

      const width = strength === 0 ? 0 : (strength / 4) * 100;
      let text = '', color = '';

      if (strength === 0) { text = 'Enter a password'; }
      else if (strength === 1) { text = 'Weak'; color = 'weak'; }
      else if (strength === 2) { text = 'Fair'; color = 'fair'; }
      else if (strength === 3) { text = 'Good'; color = 'good'; }
      else if (strength === 4) { text = 'Strong!'; color = 'strong'; }

      strengthFill.style.width = width + '%';
      strengthFill.className = 'strength-fill ' + color;
      strengthText.textContent = text;
      strengthText.style.color = strength >= 3 ? 'var(--success)' : (strength >= 1 ? 'var(--warning)' : '');

      submitBtn.disabled = strength < 3;
    });

    passwordInput.focus();
  </script>
</body>
</html>
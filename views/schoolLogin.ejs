<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>School Login — CoolManagement</title>

  <!-- Preload Inter Font + Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --card: #ffffff;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 24px;
      --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f7ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: var(--text);
    }

    .login-card {
      width: 100%;
      max-width: 480px;
      background: var(--card);
      padding: 64px 52px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border: 1px solid rgba(26, 115, 232, 0.12);
      position: relative;
      overflow: hidden;
      animation: floatIn 0.9s ease-out forwards;
    }

    .login-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 6px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo {
      width: 92px;
      height: 92px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
      font-weight: 900;
      margin: 0 auto 34px;
      box-shadow: 0 16px 38px rgba(26, 115, 232, 0.35);
      letter-spacing: -2px;
    }

    h2 {
      font-size: 36px;
      font-weight: 800;
      margin-bottom: 10px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      font-size: 16.5px;
      color: var(--text-light);
      margin-bottom: 42px;
      font-weight: 500;
    }

    .message {
      background: #fee2e2;
      color: var(--danger);
      padding: 16px 20px;
      border-radius: 14px;
      margin-bottom: 28px;
      font-weight: 600;
      border-left: 5px solid var(--danger);
      animation: shake 0.6s ease-in-out;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20% { transform: translateX(-8px); }
      40% { transform: translateX(8px); }
      60% { transform: translateX(-6px); }
      80% { transform: translateX(6px); }
    }

    form { display: grid; gap: 22px; }

    label {
      text-align: left;
      font-weight: 600;
      font-size: 15px;
      color: var(--text);
    }

    input {
      width: 100%;
      padding: 19px 22px;
      border: 2px solid #e2e8f0;
      border-radius: 16px;
      font-size: 17px;
      background: #fafafa;
      transition: var(--transition);
    }

    input:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 5px rgba(26, 115, 232, 0.16);
      transform: translateY(-1px);
    }

    button {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 19px;
      border: none;
      border-radius: 16px;
      font-size: 18.5px;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 12px 32px rgba(26, 115, 232, 0.32);
      margin-top: 8px;
    }

    button:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 45px rgba(26, 115, 232, 0.42);
    }

    button:active {
      transform: translateY(-1px);
    }

    .links {
      margin-top: 36px;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 18px;
      font-size: 15.5px;
    }

    .links a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      transition: var(--transition);
    }

    .links a:hover {
      text-decoration: underline;
      opacity: 0.9;
    }

    @media (max-width: 480px) {
      .login-card { padding: 52px 34px; }
      h2 { font-size: 31px; }
      .links { flex-direction: column; text-align: center; gap: 14px; }
    }
  </style>
</head>
<body>

  <div class="login-card">
    <div class="logo">CM</div>

    <h2>School Login</h2>
    <p class="subtitle">Welcome back! Access your school dashboard securely</p>

    <!-- Flash Message -->
    <% if (message) { %>
      <div class="message"><%= message %></div>
    <% } %>

    <form action="/school/login" method="POST" autocomplete="on">
      <label for="identifier">Email or CMS ID</label>
      <input 
        type="text" 
        name="identifier" 
        id="identifier"
        placeholder="e.g. principal@school.com or CMS12345" 
        required 
        autocomplete="username"
      />

      <label for="password">Password</label>
      <input 
        type="password" 
        name="password" 
        id="password"
        placeholder="Enter your secure password" 
        required 
        autocomplete="current-password"
      />

      <button type="submit">
        Login to Dashboard
      </button>
    </form>

    <div class="links">
      <a href="/school/forgot-password">Forgot Password?</a>
      <a href="/">Back to Home</a>
    </div>
  </div>

  <script>
    // Auto-focus first input + better UX
    document.getElementById('identifier')?.focus();
  </script>

</body>
</html>
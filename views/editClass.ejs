<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Class — EduManage.png</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/styles/nav.css" />
  <link rel="stylesheet" href="/styles/footer.css" />

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --primary-dark: #1557b0;
      --success: #10b981;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --bg: #f8fafc;
      --card: #ffffff;
      --border: #e2e8f0;
      --shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
      --radius: 20px;
      --transition: all 0.3s ease;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #f0f7ff 0%, #e0eafc 100%);
      min-height: 100vh;
      color: var(--text);
    }

    /* Header */
    .page-header {
      background: linear-gradient(135deg, var(--primary) 0%, #3367d6 100%);
      color: white;
      text-align: center;
      padding: 120px 20px 80px;
      position: relative;
      overflow: hidden;
    }

    .page-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 200"><path d="M0,100 Q300,200 600,100 T1200,100 L1200,200 L0,200 Z" fill="rgba(255,255,255,0.1)"/></svg>') bottom no-repeat;
      background-size: cover;
    }

    .page-header h1 {
      font-size: 44px;
      font-weight: 800;
      margin-bottom: 12px;
      position: relative;
    }

    .page-header p {
      font-size: 18px;
      opacity: 0.95;
      max-width: 600px;
      margin: 0 auto;
    }

    /* Form Card */
    .form-wrapper {
      max-width: 560px;
      margin: -60px auto 120px;
      padding: 0 20px;
      position: relative;
      z-index: 10;
    }

    .form-container {
      background: var(--card);
      padding: 48px 40px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      animation: floatIn 0.7s ease-out;
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .form-container h2 {
      font-size: 30px;
      text-align: center;
      margin-bottom: 32px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* Form Groups */
    .form-group {
      margin-bottom: 24px;
    }

    label {
      display: block;
      margin-bottom: 10px;
      font-weight: 600;
      color: var(--text);
      font-size: 15px;
    }

    input, select {
      width: 100%;
      padding: 16px 18px;
      border: 2px solid #e2e8f0;
      border-radius: 12px;
      font-size: 16px;
      background: #fafafa;
      transition: var(--transition);
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 4px rgba(26, 115, 232, 0.12);
    }

    select {
      cursor: pointer;
    }

    /* Submit Button */
    button {
      width: 100%;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 18px;
      border: none;
      border-radius: 12px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 8px 25px rgba(26, 115, 232, 0.3);
      margin-top: 12px;
    }

    button:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 35px rgba(26, 115, 232, 0.4);
    }

    /* Back Link */
    .back-link {
      display: block;
      text-align: center;
      margin-top: 28px;
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      font-size: 16px;
      transition: var(--transition);
    }

    .back-link:hover {
      text-decoration: underline;
    }

    /* Responsive */
    @media (max-width: 640px) {
      .page-header h1 { font-size: 36px; }
      .form-container { padding: 40px 24px; }
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <%- include("partials/nav") %>

  <!-- Page Header -->
  <section class="page-header">
    <h1>Edit Class</h1>
    <p>Update class details quickly and easily</p>
  </section>

  <!-- Edit Form -->
  <section class="form-wrapper">
    <div class="form-container">
      <h2><%= cls.className %></h2>

      <form action="/school/classes/edit/<%= cls._id %>" method="POST">
        
        <!-- Class Name -->
        <div class="form-group">
          <label for="className">Class Name</label>
          <input
            type="text"
            id="className"
            name="className"
            value="<%= cls.className %>"
            required
            placeholder="e.g., Class X-A"
          />
        </div>

        <!-- Class Teacher -->
        <div class="form-group">
          <label for="classTeacher">Class Teacher</label>
          <select id="classTeacher" name="classTeacher" required>
            <option value="">Choose a teacher</option>
            <% teachers.forEach(teacher => { %>
              <option
                value="<%= teacher._id %>"
                <%= cls.classTeacher && cls.classTeacher._id.toString() === teacher._id.toString() ? "selected" : "" %>
              >
                <%= teacher.name %> <%= teacher.subject ? `(${teacher.subject})` : '' %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Max Students -->
        <div class="form-group">
          <label for="maxStudents">Maximum Students</label>
          <input
            type="number"
            id="maxStudents"
            name="maxStudents"
            value="<%= cls.maxStudents || 40 %>"
            min="10"
            max="100"
            required
          />
        </div>

        <button type="submit">
          Update Class
        </button>
      </form>

      <a href="/school/dashboard" class="back-link">
        Back to Dashboard
      </a>
    </div>
  </section>

  <!-- Footer -->
  <%- include("partials/footer") %>

</body>
</html>
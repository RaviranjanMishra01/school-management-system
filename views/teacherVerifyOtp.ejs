<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify OTP — Teacher • CoolManagement</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --card: #ffffff;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 24px;
      --transition: all 0.4s ease;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f7ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: var(--text);
    }

    .otp-card {
      width: 100%;
      max-width: 480px;
      background: var(--card);
      padding: 56px 48px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border: 1px solid rgba(26, 115, 232, 0.12);
      position: relative;
      overflow: hidden;
      animation: floatIn 0.8s ease-out;
    }

    .otp-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 6px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 34px;
      font-weight: bold;
      margin: 0 auto 28px;
      box-shadow: 0 12px 30px rgba(26, 115, 232, 0.3);
    }

    h2 {
      font-size: 32px;
      font-weight: 800;
      margin-bottom: 12px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .info-text {
      font-size: 16px;
      color: var(--text-light);
      margin-bottom: 32px;
      line-height: 1.6;
    }

    .error {
      background: #fee2e2;
      color: var(--danger);
      padding: 14px 20px;
      border-radius: 12px;
      margin-bottom: 24px;
      font-weight: 600;
      border-left: 4px solid var(--danger);
      animation: shake 0.5s ease;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-6px); }
      75% { transform: translateX(6px); }
    }

    form {
      display: grid;
      gap: 20px;
    }

    .otp-wrapper {
      position: relative;
    }

    input[type="text"] {
      width: 100%;
      padding: 20px 56px 20px 24px;
      border: 2px solid #e2e8f0;
      border-radius: 16px;
      font-size: 28px;
      font-weight: 700;
      text-align: center;
      letter-spacing: 12px;
      background: #fafafa;
      transition: var(--transition);
      text-transform: uppercase;
    }

    input:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 5px rgba(26, 115, 232, 0.15);
    }

    .toggle-otp {
      position: absolute;
      right: 18px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: var(--text-light);
      font-size: 20px;
      transition: var(--transition);
    }

    .toggle-otp:hover { color: var(--primary); }

    button {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 18px;
      border: none;
      border-radius: 14px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      box-shadow: 0 10px 30px rgba(26, 115, 232, 0.3);
    }

    button:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(26, 115, 232, 0.4);
    }

    .resend {
      margin-top: 24px;
      font-size: 15px;
    }

    .resend a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
    }

    .resend a:hover { text-decoration: underline; }

    @media (max-width: 480px) {
      .otp-card { padding: 48px 32px; }
      h2 { font-size: 28px; }
      input[type="text"] { font-size: 24px; letter-spacing: 8px; padding: 18px 48px; }
    }
  </style>
</head>
<body>

  <div class="otp-card">
    <div class="logo">CM</div>
    
    <h2>Verify OTP</h2>
    <p class="info-text">
      We've sent a 6-digit code to<br>
      <strong><%= identifier %></strong>
    </p>

    <% if (message) { %>
      <div class="error"><%= message %></div>
    <% } %>

    <form action="/teacher/forgot-password/verify" method="POST">
      <input type="hidden" name="identifier" value="<%= identifier %>">
      
      <div class="otp-wrapper">
        <input 
          type="text" 
          name="otp" 
          id="otp"
          required 
          maxlength="6"
          minlength="6"
          inputmode="numeric"
          pattern="[0-9]{6}"
          placeholder="------"
          autocomplete="one-time-code"
        />
        <i class="fas fa-eye toggle-otp" id="toggleOtp"></i>
      </div>
      
      <button type="submit">
        Verify & Continue
      </button>
    </form>

    <div class="resend">
      Didn't receive it? 
      <a href="/teacher/forgot-password">Resend OTP</a>
    </div>
  </div>

  <script>
    const otpInput = document.getElementById('otp');
    const toggleOtp = document.getElementById('toggleOtp');

    // Auto-focus
    otpInput.focus();

    // Toggle visibility (optional)
    toggleOtp.addEventListener('click', () => {
      const type = otpInput.type === 'password' ? 'text' : 'password';
      otpInput.type = type;
      toggleOtp.classList.toggle('fa-eye');
      toggleOtp.classList.toggle('fa-eye-slash');
    });

    // Auto-submit on 6 digits (optional UX boost)
    otpInput.addEventListener('input', () => {
      if (otpInput.value.length === 6) {
        otpInput.closest('form').submit();
      }
    });
  </script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About — EduManage.png</title>
  
  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/styles/nav.css" />
  <link rel="stylesheet" href="/styles/footer.css" />

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --primary-dark: #1557b0;
      --text: #1e293b;
      --text-light: #64748b;
      --bg: #f8fafc;
      --card: #ffffff;
      --border: #e2e8f0;
      --success: #10b981;
      --radius: 20px;
      --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    /* Hero Section (fixed gradient and overlay) */
    .hero {
      background: linear-gradient(135deg, var(--primary) 0%, #3367d6 100%);
      color: white;
      text-align: center;
      padding: 140px 20px 100px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAxMjAwIDMwMCI+PHBhdGggZD0iTTAsMTUwIEMzMDAsMjUwLDYwMCwyNTAsOTAwLDE1MCBMMTIwMCwxNTAgTDEyMDAsMzAwIEwwLDMwMCBaIiBmaWxsPSJyZ2JhKDI1NSwyNTUsMjU1LDAuMSkiLz48L3N2Zz4=') bottom no-repeat;
      background-size: cover;
      pointer-events: none;
    }

    .hero h1 {
      font-size: 52px;
      font-weight: 800;
      margin-bottom: 20px;
      letter-spacing: -0.5px;
      position: relative;
      animation: fadeInUp 0.8s ease;
    }

    .hero p {
      font-size: 20px;
      max-width: 700px;
      margin: 0 auto;
      opacity: 0.95;
      font-weight: 500;
      animation: fadeInUp 0.8s ease 0.1s both;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Container */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 24px;
    }

    .section-title {
      font-size: 40px;
      font-weight: 800;
      text-align: center;
      margin-bottom: 20px;
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
    }

    .section-subtitle {
      text-align: center;
      font-size: 18px;
      color: var(--text-light);
      max-width: 700px;
      margin: 0 auto 60px;
    }

    /* About Cards Grid */
    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
      gap: 32px;
      margin: 60px 0 40px;
    }

    .about-card {
      background: var(--card);
      padding: 44px 32px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      transition: var(--transition);
      border: 1px solid rgba(0,0,0,0.05);
      position: relative;
      overflow: hidden;
    }

    .about-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
      transform: scaleX(0);
      transition: transform 0.4s;
    }

    .about-card:hover::before {
      transform: scaleX(1);
    }

    .about-card:hover {
      transform: translateY(-12px);
      box-shadow: 0 20px 40px rgba(26, 115, 232, 0.15);
      border-color: var(--primary-light);
    }

    .about-card i {
      font-size: 52px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 24px;
      display: inline-block;
    }

    .about-card h3 {
      font-size: 26px;
      font-weight: 700;
      margin-bottom: 16px;
      color: var(--text);
    }

    .about-card p {
      color: var(--text-light);
      font-size: 15px;
      line-height: 1.65;
    }

    /* Features Section */
    .features {
      background: white;
      padding: 70px 32px;
      margin: 60px auto;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 32px;
      margin-top: 50px;
    }

    .feature-item {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      padding: 20px;
      background: #f8fafc;
      border-radius: 18px;
      transition: var(--transition);
      border: 1px solid transparent;
    }

    .feature-item:hover {
      background: white;
      border-color: var(--primary-light);
      transform: translateX(8px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    .feature-icon {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      flex-shrink: 0;
      box-shadow: 0 10px 20px rgba(26, 115, 232, 0.25);
    }

    .feature-content h4 {
      font-size: 19px;
      font-weight: 700;
      margin-bottom: 10px;
      color: var(--text);
    }

    .feature-content p {
      color: var(--text-light);
      font-size: 14.5px;
      line-height: 1.5;
    }

    /* CTA Section */
    .cta-section {
      text-align: center;
      padding: 90px 32px;
      background: linear-gradient(135deg, var(--primary) 0%, #3367d6 100%);
      border-radius: var(--radius);
      margin: 60px 0 0;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .cta-section::after {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(255,255,255,0.15), transparent);
      border-radius: 50%;
    }

    .cta-section h2 {
      font-size: 44px;
      font-weight: 800;
      margin-bottom: 20px;
      letter-spacing: -0.5px;
    }

    .cta-section p {
      font-size: 18px;
      max-width: 650px;
      margin: 0 auto 35px;
      opacity: 0.95;
    }

    .btn {
      display: inline-block;
      background: white;
      color: var(--primary) !important;
      padding: 16px 44px;
      border-radius: 60px;
      font-weight: 700;
      font-size: 18px;
      text-decoration: none;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
      transition: var(--transition);
      border: none;
    }

    .btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 35px rgba(0, 0, 0, 0.25);
      background: #fefefe;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero h1 { font-size: 38px; }
      .hero p { font-size: 18px; }
      .section-title { font-size: 32px; }
      .cta-section h2 { font-size: 32px; }
      .cta-section p { font-size: 16px; }
      .features { padding: 40px 20px; }
      .about-card { padding: 32px 24px; }
    }

    @media (max-width: 480px) {
      .container { padding: 50px 16px; }
      .feature-item { flex-direction: column; text-align: center; align-items: center; }
      .feature-icon { margin-bottom: 12px; }
    }
  </style>
</head>

<body>
  <!-- Navbar -->
  <%- include("partials/nav") %>

  <!-- Hero Section -->
  <section class="hero">
    <h1>About EduManage.png</h1>
    <p>Empowering educational institutions with modern, intuitive, and powerful school management tools</p>
  </section>

  <!-- Main Content -->
  <div class="container">

    <!-- Who We Are -->
    <div class="about-grid">
      <div class="about-card">
        <i class="fas fa-users"></i>
        <h3>Who We Are</h3>
        <p>EduManage.png is a next-generation School Management Platform built to simplify operations and enhance digital learning experiences for schools across India and beyond.</p>
      </div>
      <div class="about-card">
        <i class="fas fa-bullseye"></i>
        <h3>Our Mission</h3>
        <p>To make school administration effortless, transparent, and efficient — so educators can focus on what truly matters: teaching and nurturing students.</p>
      </div>
      <div class="about-card">
        <i class="fas fa-eye"></i>
        <h3>Our Vision</h3>
        <p>A world where every school runs smoothly with smart technology, fostering better communication, accountability, and academic excellence.</p>
      </div>
    </div>

    <!-- Features Section -->
    <section class="features">
      <h2 class="section-title">Why Thousands Trust EduManage.png</h2>
      <p class="section-subtitle">Everything you need to run a modern, digital-first school — all in one platform</p>

      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-icon"><i class="fas fa-check-circle"></i></div>
          <div class="feature-content">
            <h4>Super Easy to Use</h4>
            <p>Intuitive interface designed for teachers, staff, and parents — no training required</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
          <div class="feature-content">
            <h4>Bank-Level Security</h4>
            <p>Secure cloud storage with encryption, backups, and role-based access control</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="fas fa-mobile-alt"></i></div>
          <div class="feature-content">
            <h4>Mobile Ready</h4>
            <p>Access from anywhere — teachers mark attendance, parents view results instantly</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="fas fa-bolt"></i></div>
          <div class="feature-content">
            <h4>Lightning Fast</h4>
            <p>Built for performance — works smoothly even on low-end devices and slow internet</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="fas fa-headset"></i></div>
          <div class="feature-content">
            <h4>24/7 Support</h4>
            <p>Dedicated support team + WhatsApp & call assistance whenever you need</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="fas fa-rupee-sign"></i></div>
          <div class="feature-content">
            <h4>Affordable Pricing</h4>
            <p>Transparent plans that grow with your school — no hidden charges</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <div class="cta-section">
      <h2>Ready to Transform Your School?</h2>
      <p>Join hundreds of schools already using EduManage.png to save time, reduce paperwork, and focus on education</p>
      <a href="/school/create" class="btn">
        <i class="fas fa-rocket"></i> Create Your School Free
      </a>
    </div>
  </div>

  <!-- Footer -->
  <%- include("partials/footer") %>
</body>
</html>
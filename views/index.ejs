<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CoolManagement — Welcome</title>
  <meta name="description" content="CoolManagement — Modern school management system for teachers, students, classes, attendance, exams, and parent communication." />

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --primary: #1a73e8;
      --primary-light: #4285f4;
      --primary-dark: #1557b0;
      --text: #1e293b;
      --text-light: #64748b;
      --bg-start: #eef2ff;
      --bg-end: #f8fafc;
      --card: #ffffff;
      --shadow: 0 20px 50px rgba(26, 115, 232, 0.15);
      --radius: 24px;
      --transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, var(--bg-start) 0%, var(--bg-end) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px;
      color: var(--text);
    }

    .welcome-card {
      width: 100%;
      max-width: 560px;
      background: var(--card);
      padding: 60px 50px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border: 1px solid rgba(26, 115, 232, 0.12);
      animation: floatIn 0.9s ease-out;
      position: relative;
      overflow: hidden;
    }

    .welcome-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 6px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }

    @keyframes floatIn {
      from {
        opacity: 0;
        transform: translateY(40px) scale(0.95);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .logo {
      width: 90px;
      height: 90px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      font-weight: bold;
      margin: 0 auto 28px;
      box-shadow: 0 12px 30px rgba(26, 115, 232, 0.3);
    }

    h1 {
      font-size: 38px;
      font-weight: 800;
      margin-bottom: 16px;
      background: linear-gradient(90deg, var(--primary), #3367d6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    p {
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-light);
      margin-bottom: 40px;
      max-width: 460px;
      margin-left: auto;
      margin-right: auto;
    }

    .btn-primary {
      display: inline-block;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      padding: 18px 48px;
      border-radius: 50px;
      font-size: 18px;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 12px 30px rgba(26, 115, 232, 0.3);
      transition: var(--transition);
    }

    .btn-primary:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(26, 115, 232, 0.4);
    }

    .btn-primary:active {
      transform: translateY(-2px);
    }

    .extra-links {
      margin-top: 32px;
      font-size: 15px;
    }

    .extra-links a {
      color: var(--text-light);
      text-decoration: none;
      margin: 0 12px;
      transition: var(--transition);
    }

    .extra-links a:hover {
      color: var(--primary);
      text-decoration: underline;
    }

    /* Responsive */
    @media (max-width: 580px) {
      .welcome-card {
        padding: 48px 32px;
      }
      h1 {
        font-size: 32px;
      }
      p {
        font-size: 16px;
      }
      .btn-primary {
        padding: 16px 40px;
        font-size: 17px;
      }
    }
  </style>
</head>
<body>

  <div class="welcome-card" role="main" aria-labelledby="welcome-title">

    <div class="logo">CM</div>

    <h1 id="welcome-title">Welcome to CoolManagement</h1>

    <p>
      The modern, all-in-one school management platform trusted by hundreds of schools across India. 
      Manage teachers, students, classes, attendance, exams, results, and parent communication — 
      all from one beautiful dashboard.
    </p>

    <a href="/home" class="btn-primary" aria-label="Go to CoolManagement homepage">
      Go to Homepage
    </a>

    <div class="extra-links">
      <a href="/school/create">Create School</a> • 
      <a href="/school/login">School Login</a> • 
      <a href="/teacher/login">Teacher Login</a>
    </div>

  </div>

</body>
</html>